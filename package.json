{
  "name": "fabx-cli",
  "version": "0.1.0",
  "description": "Fabx CLI - generate docker-compose and manage Fabric-X locally",
  "bin": {
    "fabx": "./bin/run.js"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node lib/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "check:network": "node ./bin/run.js check",
    "validate:mvp": "node ./scripts/validate-mvp.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@oclif/core": "^2.0.0",
    "ejs": "^3.1.9",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
  ,
  "oclif": {
    "commands": "./lib/commands"
  }
}
