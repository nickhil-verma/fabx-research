services:
  committer:
    image: ghcr.io/hyperledger/fabric-x-committer-test-node:0.1.9
    container_name: fabricx_committer
    command: ["run", "db", "orderer", "committer", "--insecure"]
    ports:
      - "7050:7050"
      - "4001:4001"
      - "7001:7001"
    volumes:
      - ../fabric-x/tools/fxconfig/integration/testdata:/root/artifacts:ro
    networks:
      fabx_net:
        aliases:
          - committer
          - committer-sidecar
          - committer-queryservice

  issuer:
    build:
      context: ../fabric-x/samples/tokens
      dockerfile: Dockerfile
      args:
        NODE_TYPE: issuer
        PLATFORM: "${PLATFORM:-fabricx}"
    container_name: fabricx_issuer
    hostname: issuer.example.com
    ports:
      - "9100:9000"
      - "9101:9101"
    volumes:
      - ../config/issuer:/conf
    networks:
      fabx_net:
        aliases:
          - issuer.example.com
    depends_on:
      - committer

  endorser:
    build:
      context: ../fabric-x/samples/tokens
      dockerfile: Dockerfile
      args:
        NODE_TYPE: endorser
        PLATFORM: "${PLATFORM:-fabricx}"
    container_name: fabricx_endorser
    hostname: endorser1.example.com
    ports:
      - "9300:9000"
      - "9301:9301"
    volumes:
      - ../config/endorser:/conf
      - ../config/namespace/zkatdlognoghv1_pp.json:/namespace/zkatdlognoghv1_pp.json:ro
    networks:
      fabx_net:
        aliases:
          - endorser1.example.com
    depends_on:
      - committer
      - issuer

  owner:
    build:
      context: ../fabric-x/samples/tokens
      dockerfile: Dockerfile
      args:
        NODE_TYPE: owner
        PLATFORM: "${PLATFORM:-fabricx}"
    container_name: fabricx_owner
    hostname: owner1.example.com
    ports:
      - "9500:9000"
      - "9501:9501"
    volumes:
      - ../config/owner:/conf
    networks:
      fabx_net:
        aliases:
          - owner1.example.com
    depends_on:
      - committer
      - issuer
      - endorser

<% if (config.enableMonitoring) { %>
  prometheus:
    image: prom/prometheus:latest
    container_name: <%= config.network %>_prometheus
    ports:
      - "9090:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro

  grafana:
    image: grafana/grafana:latest
    container_name: <%= config.network %>_grafana
    ports:
      - "3000:3000"
<% } %>

networks:
  fabx_net:
    driver: bridge
