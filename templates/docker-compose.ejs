services:
  committer:
    image: ghcr.io/hyperledger/fabric-x-committer-test-node:0.1.9
    container_name: fabricx_committer
    command: ["run", "db", "orderer", "committer", "--insecure"]
    ports:
      - "7050:7050"
      - "4001:4001"
      - "7001:7001"
    volumes:
      - ../fabric-x/tools/fxconfig/integration/testdata:/root/artifacts:ro
    networks:
      fabx_net:
        aliases:
          - committer
          - committer-sidecar
          - committer-queryservice

  issuer:
    build:
      context: ../fabric-x/samples/tokens
      dockerfile: Dockerfile
      args:
        NODE_TYPE: issuer
        PLATFORM: "${PLATFORM:-fabricx}"
    container_name: fabricx_issuer
    hostname: issuer.example.com
    ports:
      - "9100:9000"
      - "9101:9101"
    volumes:
      - ../config/issuer:/conf
    networks:
      fabx_net:
        aliases:
          - issuer.example.com
    depends_on:
      - committer

  endorser:
    build:
      context: ../fabric-x/samples/tokens
      dockerfile: Dockerfile
      args:
        NODE_TYPE: endorser
        PLATFORM: "${PLATFORM:-fabricx}"
    container_name: fabricx_endorser
    hostname: endorser1.example.com
    ports:
      - "9300:9000"
      - "9301:9301"
    volumes:
      - ../config/endorser:/conf
      - ../config/namespace/zkatdlognoghv1_pp.json:/namespace/zkatdlognoghv1_pp.json:ro
    networks:
      fabx_net:
        aliases:
          - endorser1.example.com
    depends_on:
      - committer
      - issuer

  owner:
    build:
      context: ../fabric-x/samples/tokens
      dockerfile: Dockerfile
      args:
        NODE_TYPE: owner
        PLATFORM: "${PLATFORM:-fabricx}"
    container_name: fabricx_owner
    hostname: owner1.example.com
    ports:
      - "9500:9000"
      - "9501:9501"
    volumes:
      - ../config/owner:/conf
    networks:
      fabx_net:
        aliases:
          - owner1.example.com
    depends_on:
      - committer
      - issuer
      - endorser

<% if (config.enableMonitoring) { %>
  prometheus:
    image: prom/prometheus:latest
    container_name: <%= config.network %>_prometheus
    ports:
      - "9090:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
    networks:
      fabx_net:
        aliases:
          - prometheus
    depends_on:
      - transaction-exporter
      - blackbox-exporter

  blackbox-exporter:
    image: prom/blackbox-exporter:latest
    container_name: <%= config.network %>_blackbox_exporter
    command:
      - "--config.file=/etc/blackbox_exporter/config.yml"
    ports:
      - "9115:9115"
    volumes:
      - ./blackbox.yml:/etc/blackbox_exporter/config.yml:ro
    networks:
      fabx_net:
        aliases:
          - blackbox-exporter

  transaction-exporter:
    image: node:20-alpine
    container_name: <%= config.network %>_transaction_exporter
    working_dir: /app
    command: ["node", "/app/scripts/transaction-exporter.js"]
    environment:
      OWNER_API_BASE: http://owner:9000
      ACCOUNT_ID: alice
      PORT: "2112"
      POLL_INTERVAL_MS: "5000"
    ports:
      - "2112:2112"
    volumes:
      - ../scripts:/app/scripts:ro
    networks:
      fabx_net:
        aliases:
          - transaction-exporter
    depends_on:
      - owner

  grafana:
    image: grafana/grafana:latest
    container_name: <%= config.network %>_grafana
    ports:
      - "3000:3000"
    environment:
      GF_SECURITY_ADMIN_USER: admin
      GF_SECURITY_ADMIN_PASSWORD: admin
      GF_USERS_ALLOW_SIGN_UP: "false"
    volumes:
      - ./grafana/provisioning/datasources:/etc/grafana/provisioning/datasources:ro
      - ./grafana/provisioning/dashboards:/etc/grafana/provisioning/dashboards:ro
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
    networks:
      fabx_net:
        aliases:
          - grafana
    depends_on:
      - prometheus
<% } %>

networks:
  fabx_net:
    driver: bridge
