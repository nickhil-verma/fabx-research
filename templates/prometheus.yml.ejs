global:
  scrape_interval: 5s

scrape_configs:
  - job_name: 'fabx-transaction-exporter'
    static_configs:
      - targets: ['transaction-exporter:2112']

  - job_name: 'fabx-health-probes'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - http://issuer:9000/healthz
          - http://endorser:9000/healthz
          - http://owner:9000/healthz
          - http://issuer:9000/readyz
          - http://endorser:9000/readyz
          - http://owner:9000/readyz
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115
